//@version=5
// Chinna Trading Scanner — Intraday Strategy
// Conditions: EMA200 macro + EMA9/21 micro + daily-anchored VWAP + RSI<55 pullback + EMA9 candle test
// Timeframe: 5-min intraday | SL=1.5×ATR | TP=2.0×ATR | RR≥1:1.3
strategy(
     title       = "Chinna Trading — 5-Condition Intraday",
     overlay     = true,
     default_qty_type  = strategy.percent_of_equity,
     default_qty_value = 10,
     commission_type   = strategy.commission.percent,
     commission_value  = 0.05,
     slippage    = 2
 )

// ── Inputs ───────────────────────────────────────────────────────────────────
ema9Len   = input.int(9,   "EMA Fast",   minval=1)
ema21Len  = input.int(21,  "EMA Slow",   minval=1)
ema200Len = input.int(200, "EMA Macro",  minval=1)
rsiLen    = input.int(14,  "RSI Length", minval=1)
rsiThresh = input.float(55,"RSI Threshold", minval=20, maxval=80)
atrLen    = input.int(14,  "ATR Length", minval=1)
slMult    = input.float(1.5,"SL Multiplier", minval=0.5, step=0.1)
tpMult    = input.float(2.0,"TP Multiplier", minval=0.5, step=0.1)

// ── Indicators ───────────────────────────────────────────────────────────────
ema9   = ta.ema(close, ema9Len)
ema21  = ta.ema(close, ema21Len)
ema200 = ta.ema(close, ema200Len)
rsi    = ta.rsi(close, rsiLen)
atr    = ta.atr(atrLen)

// Daily-anchored VWAP: reset at the start of each session
isNewDay  = ta.change(time("D")) != 0
var float cumTPV = 0.0
var float cumVol = 0.0
if isNewDay
    cumTPV := 0.0
    cumVol := 0.0
typical   = (high + low + close) / 3
cumTPV   += typical * volume
cumVol   += volume
avwap     = cumVol > 0 ? cumTPV / cumVol : close

// ── 5 Conditions ─────────────────────────────────────────────────────────────
c1 = close > ema200                      // macro uptrend
c2 = ema9  > ema21                       // micro momentum
c3 = close > avwap                       // above anchored VWAP
c4 = rsi   < rsiThresh                   // pullback zone (not overbought)
c5 = math.abs(low - ema9) <= atr * 0.5  // candle tests / touches EMA9

passed = (c1 ? 1 : 0) + (c2 ? 1 : 0) + (c3 ? 1 : 0) + (c4 ? 1 : 0) + (c5 ? 1 : 0)

buySignal   = passed == 5
watchSignal = passed >= 3 and passed < 5

// ── Entries & Exits ──────────────────────────────────────────────────────────
inLong = strategy.opentrades > 0

if buySignal and not inLong
    sl = close - slMult * atr
    tp = close + tpMult * atr
    strategy.entry("LONG", strategy.long, comment="BUY " + str.tostring(passed) + "/5")
    strategy.exit("EXIT", "LONG", stop=sl, limit=tp, comment="SL/TP")

// ── Plots ─────────────────────────────────────────────────────────────────────
plot(ema9,   "EMA 9",   color=color.new(color.aqua,  0), linewidth=1)
plot(ema21,  "EMA 21",  color=color.new(color.orange, 0), linewidth=1)
plot(ema200, "EMA 200", color=color.new(color.gray,   20), linewidth=2)
plot(avwap,  "AVWAP",   color=color.new(color.yellow, 0), linewidth=2, style=plot.style_line)

// ── Signal Labels ─────────────────────────────────────────────────────────────
if buySignal and not inLong[1]
    label.new(
         bar_index, low - atr * 0.3,
         text  = "▲ BUY\nSL " + str.tostring(math.round(close - slMult * atr, 2)) +
                 "\nTP " + str.tostring(math.round(close + tpMult * atr, 2)),
         color = color.new(color.green, 0),
         textcolor = color.white,
         style = label.style_label_up,
         size  = size.small
     )

if watchSignal and barstate.isconfirmed
    label.new(
         bar_index, low - atr * 0.6,
         text  = "● WATCH " + str.tostring(passed) + "/5",
         color = color.new(color.orange, 30),
         textcolor = color.white,
         style = label.style_label_up,
         size  = size.tiny
     )

// Background — in position
bgcolor(inLong ? color.new(color.green, 92) : na)

// ── Dashboard Table ───────────────────────────────────────────────────────────
var table dash = table.new(position.top_right, 2, 7,
     border_color = color.new(color.gray, 50),
     border_width = 1,
     bgcolor      = color.new(color.black, 70)
 )

f_cell(col, row, txt, ok) =>
    table.cell(dash, col, row,
         text      = txt,
         text_size = size.small,
         text_color = ok ? color.lime : color.gray,
         bgcolor   = color.new(color.black, 80)
     )

table.cell(dash, 0, 0, "CONDITION", text_size=size.small, text_color=color.white, bgcolor=color.new(color.navy,50))
table.cell(dash, 1, 0, "STATUS",    text_size=size.small, text_color=color.white, bgcolor=color.new(color.navy,50))

f_cell(0, 1, "C1 Price > EMA200",   c1)
f_cell(1, 1, c1 ? "✓" : "✗",       c1)
f_cell(0, 2, "C2 EMA9 > EMA21",     c2)
f_cell(1, 2, c2 ? "✓" : "✗",       c2)
f_cell(0, 3, "C3 Price > AVWAP",    c3)
f_cell(1, 3, c3 ? "✓" : "✗",       c3)
f_cell(0, 4, "C4 RSI < " + str.tostring(rsiThresh), c4)
f_cell(1, 4, c4 ? "✓" : "✗",       c4)
f_cell(0, 5, "C5 Low ≈ EMA9",       c5)
f_cell(1, 5, c5 ? "✓" : "✗",       c5)

sigColor = passed == 5 ? color.new(color.green, 0) : passed >= 3 ? color.new(color.orange, 0) : color.new(color.gray, 0)
table.cell(dash, 0, 6, "SIGNAL", text_size=size.small, text_color=color.white, bgcolor=color.new(color.black, 80))
table.cell(dash, 1, 6,
     passed == 5 ? "BUY" : passed >= 3 ? "WATCH " + str.tostring(passed) + "/5" : "NONE",
     text_size  = size.small,
     text_color = sigColor,
     bgcolor    = color.new(color.black, 80)
 )
