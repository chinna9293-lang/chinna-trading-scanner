//@version=6
indicator("Quant Trading Signals", overlay=true)

// INPUTS
rsi_len = input(14, "RSI")
ema_fast = input(9, "EMA Fast")
ema_slow = input(21, "EMA Slow")
lookback = input(20, "Lookback")

// 1. MEAN REVERSION
rsi = ta.rsi(close, rsi_len)
mean_rev_buy = rsi < 30
mean_rev_sell = rsi > 70

// 2. MOMENTUM
ema9 = ta.ema(close, ema_fast)
ema21 = ta.ema(close, ema_slow)
momentum_buy = ema9 > ema21
momentum_sell = ema9 < ema21

// 3. BREAKOUT
h = ta.highest(high, lookback)
l = ta.lowest(low, lookback)
breakout_buy = close > h[1]
breakout_sell = close < l[1]

// 4. STAT ARB
sma = ta.sma(close, lookback)
dev = ta.stdev(close, lookback)
zs = (close - sma) / dev
arb_buy = zs < -1.5
arb_sell = zs > 1.5

// 5. VOLATILITY
atr = ta.atr(14)
vol_pct = atr / close * 100
vol_buy = vol_pct < 2
vol_sell = vol_pct > 3

// 6. KELLY
win_rate = rsi / 100
kelly_buy = win_rate > 0.55
kelly_sell = win_rate < 0.45

// COMBINE
buy_count = (mean_rev_buy ? 1 : 0) + (momentum_buy ? 1 : 0) + (breakout_buy ? 1 : 0) + (arb_buy ? 1 : 0) + (vol_buy ? 1 : 0) + (kelly_buy ? 1 : 0)
sell_count = (mean_rev_sell ? 1 : 0) + (momentum_sell ? 1 : 0) + (breakout_sell ? 1 : 0) + (arb_sell ? 1 : 0) + (vol_sell ? 1 : 0) + (kelly_sell ? 1 : 0)

strong_buy = buy_count >= 4
strong_sell = sell_count >= 4

// SIGNALS
if strong_buy
    label.new(bar_index, low, text="BUY", color=color.green, textcolor=color.white, style=label.style_label_up)

if strong_sell
    label.new(bar_index, high, text="SELL", color=color.red, textcolor=color.white, style=label.style_label_down)
