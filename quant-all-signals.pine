//@version=6
strategy("Quant Trading - Best Trades Only", overlay=true, default_qty_type=strategy.fixed, default_qty_value=100)

// INPUTS
rsi_len = input(14, "RSI")
ema_fast = input(9, "EMA Fast")
ema_slow = input(21, "EMA Slow")
lookback = input(20, "Lookback")
adx_len = input(14, "ADX Length")
adx_threshold = input(25, "ADX Threshold")

// 1. MEAN REVERSION
rsi = ta.rsi(close, rsi_len)
mean_rev_buy = rsi < 30
mean_rev_sell = rsi > 70

// 2. MOMENTUM
ema9 = ta.ema(close, ema_fast)
ema21 = ta.ema(close, ema_slow)
momentum_buy = ema9 > ema21 and ema9[1] <= ema21[1]
momentum_sell = ema9 < ema21 and ema9[1] >= ema21[1]

// 3. BREAKOUT
h = ta.highest(high, lookback)
l = ta.lowest(low, lookback)
breakout_buy = close > h[1] and close[1] <= h[1]
breakout_sell = close < l[1] and close[1] >= l[1]

// 4. STAT ARB
sma = ta.sma(close, lookback)
dev = ta.stdev(close, lookback)
zs = (close - sma) / dev
arb_buy = zs < -1.5
arb_sell = zs > 1.5

// 5. VOLATILITY
atr = ta.atr(14)
vol_pct = atr / close * 100
vol_buy = vol_pct < 2 and close > ema21
vol_sell = vol_pct > 3 or (vol_pct < 2 and close < ema21)

// 6. KELLY
win_rate = rsi / 100
kelly_buy = win_rate > 0.55
kelly_sell = win_rate < 0.45

// ═════════════════════════════════════════════════════════════════
// STRICT QUALITY FILTERS - Only best trades
// ═════════════════════════════════════════════════════════════════

// TREND: Price must be above EMA21
trend_ok = close > ema21

// ADX: Strong trend confirmation (ADX > 25)
di_plus = ta.rma(math.max(high - high[1], 0), adx_len)
di_minus = ta.rma(math.max(low[1] - low, 0), adx_len)
di_sum = di_plus + di_minus
adx = di_sum == 0 ? 0 : 100 * ta.rma(math.abs(di_plus - di_minus) / di_sum, adx_len)
trend_strength = adx > adx_threshold

// VOLUME: Very strong spike (> 2.5x average)
avg_vol = ta.sma(volume, 20)
strong_vol = volume > (avg_vol * 2.5)

// RSI ZONE: Optimal range (50-65 for buy, 35-50 for sell)
rsi_buy_zone = rsi >= 50 and rsi <= 65
rsi_sell_zone = rsi >= 35 and rsi <= 50

// CANDLE BODY: Strong candle (body > 70% of range)
candle_range = high - low
candle_body = math.abs(close - open)
strong_candle = candle_body > (candle_range * 0.70)

// ═════════════════════════════════════════════════════════════════
// STRATEGY VOTES
// ═════════════════════════════════════════════════════════════════

buy_votes = (mean_rev_buy ? 1 : 0) + (momentum_buy ? 1 : 0) + (breakout_buy ? 1 : 0) + (arb_buy ? 1 : 0) + (vol_buy ? 1 : 0) + (kelly_buy ? 1 : 0)
sell_votes = (mean_rev_sell ? 1 : 0) + (momentum_sell ? 1 : 0) + (breakout_sell ? 1 : 0) + (arb_sell ? 1 : 0) + (vol_sell ? 1 : 0) + (kelly_sell ? 1 : 0)

// STRICT: Require 5+ votes AND all quality filters
best_buy = buy_votes >= 5 and trend_ok and trend_strength and strong_vol and rsi_buy_zone and strong_candle
best_sell = sell_votes >= 5 and trend_ok and trend_strength and strong_vol and rsi_sell_zone and strong_candle

// ═════════════════════════════════════════════════════════════════
// POSITION TRACKING
// ═════════════════════════════════════════════════════════════════

in_position = strategy.opentrades > 0

if best_buy and not in_position
    strategy.entry("LONG", strategy.long, comment="BEST BUY")

if best_sell and in_position
    strategy.close("LONG", comment="BEST SELL")

// ═════════════════════════════════════════════════════════════════
// DISPLAY
// ═════════════════════════════════════════════════════════════════

if best_buy and not in_position
    label.new(bar_index, low, text="BUY " + str.tostring(buy_votes) + "/6",
              color=color.new(color.green, 0), textcolor=color.white,
              style=label.style_label_up, size=size.large,
              tooltip="✓ Trend ✓ ADX ✓ Vol ✓ RSI ✓ Candle")

if best_sell and in_position
    label.new(bar_index, high, text="SELL " + str.tostring(sell_votes) + "/6",
              color=color.new(color.red, 0), textcolor=color.white,
              style=label.style_label_down, size=size.large,
              tooltip="✓ Trend ✓ ADX ✓ Vol ✓ RSI ✓ Candle")

// Position indicator
bgcolor(in_position ? color.new(color.green, 90) : na)

// Status table
info = table.new(position.top_right, 2, 3, border_color=color.gray, border_width=1)

table.cell(info, 0, 0, text="BEST TRADES ONLY", text_size=size.small, bgcolor=color.navy, text_color=color.white)
table.cell(info, 1, 0, text=in_position ? "LONG" : "FLAT", text_size=size.small, bgcolor=in_position ? color.green : color.gray, text_color=color.white)

table.cell(info, 0, 1, text="Criteria Met", text_size=size.small)
met = (trend_ok ? 1 : 0) + (trend_strength ? 1 : 0) + (strong_vol ? 1 : 0) + (rsi_buy_zone or rsi_sell_zone ? 1 : 0) + (strong_candle ? 1 : 0)
table.cell(info, 1, 1, text=str.tostring(met) + "/5 Filters", text_size=size.small, bgcolor=met == 5 ? color.new(color.green, 80) : color.new(color.orange, 80))

table.cell(info, 0, 2, text="Strategy Votes", text_size=size.small)
votes = buy_votes > 0 ? buy_votes : sell_votes
table.cell(info, 1, 2, text=str.tostring(votes) + "/6 Agree", text_size=size.small, bgcolor=votes >= 5 ? color.new(color.green, 80) : color.new(color.gray, 80))
