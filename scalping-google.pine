//@version=5
strategy("GOOGL Scalping", overlay=true)

// INPUTS
rsi_len = input(14, "RSI")
rsi_thresh = input(60, "RSI Threshold")
sr_look = input(20, "SR Lookback")
vol_mult = input(1.5, "Volume Mult")
tp_pct = input(2.5, "TP %")
sl_pct = input(1.33, "SL %")
max_bars = input(180, "Max Bars")

// CALCULATIONS
rsi = ta.rsi(close, rsi_len)
swing_h = ta.highest(high, sr_look)
swing_l = ta.lowest(low, sr_look)
resist = swing_h[1]
supp = swing_l[1]

breakout = close > resist and close[1] <= resist
avg_vol = ta.sma(volume, 20)
vol_spike = volume > (avg_vol * vol_mult)

entry = breakout and rsi > rsi_thresh and vol_spike

in_pos = strategy.opentrades > 0
entry_px = strategy.position_avg_price
bars_h = bar_index - strategy.opentrades.entry_bar_index(0)

tp = entry_px * (1 + tp_pct / 100)
sl = entry_px * (1 - sl_pct / 100)

tp_hit = in_pos and close >= tp
sl_hit = in_pos and close <= sl
time_hit = in_pos and bars_h >= max_bars

// PLOTS
plot(resist, "Resistance", color=color.red, linewidth=2, style=plot.style_dashed)
plot(supp, "Support", color=color.blue, linewidth=2, style=plot.style_dashed)
plot(in_pos ? tp : na, "TP", color=color.green, linewidth=2, style=plot.style_dashed)
plot(in_pos ? sl : na, "SL", color=color.red, linewidth=2, style=plot.style_dashed)

// SIGNALS
plotshape(entry, title="BUY", style=shape.labelup, location=location.belowbar, color=color.green, size=size.large, text="BUY")
plotshape(tp_hit, title="TARGET", style=shape.labeldown, location=location.abovebar, color=color.lime, size=size.large, text="TARGET")
plotshape(sl_hit, title="STOP", style=shape.labeldown, location=location.abovebar, color=color.red, size=size.large, text="STOP")
plotshape(time_hit and not tp_hit and not sl_hit, title="TIME", style=shape.labeldown, location=location.abovebar, color=color.orange, size=size.large, text="TIME")

// RSI
plot(rsi, "RSI", color=color.blue, linewidth=1)
hline(60, "60", color=color.orange, linestyle=hline.style_dashed)
hline(50, "50", color=color.gray)

// VOLUME
barcolor(volume > avg_vol * 1.5 ? color.new(color.green, 80) : color.new(color.gray, 80))

// LABELS
if entry
    label.new(bar_index, low * 0.99, text="WHY ENTER:\n✓ Breakout $" + str.tostring(resist, "#.00") + "\n✓ RSI " + str.tostring(rsi, "0.0"), color=color.new(color.green, 80), textcolor=color.white, style=label.style_label_up, size=size.small)

if tp_hit
    label.new(bar_index, high * 1.01, text="TARGET HIT\n+2.5%", color=color.new(color.green, 80), textcolor=color.white, style=label.style_label_down, size=size.small)

if sl_hit
    label.new(bar_index, high * 1.01, text="STOP HIT\n-1.33%", color=color.new(color.red, 80), textcolor=color.white, style=label.style_label_down, size=size.small)

if time_hit and not tp_hit and not sl_hit
    label.new(bar_index, high * 1.01, text="TIME EXIT\n30min", color=color.new(color.orange, 80), textcolor=color.white, style=label.style_label_down, size=size.small)

// STRATEGY
if entry and not in_pos
    strategy.entry("LONG", strategy.long)

if tp_hit or sl_hit or time_hit
    strategy.close("LONG")

// ALERTS
alertcondition(entry, title="BUY", message="GOOGL BUY")
alertcondition(tp_hit, title="TARGET", message="GOOGL TARGET")
alertcondition(sl_hit, title="STOP", message="GOOGL STOP")
