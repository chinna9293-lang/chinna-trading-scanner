//@version=5
strategy("GOOGL Scalping: Entry & Exit Analysis", overlay=true, default_qty_type=strategy.fixed, default_qty_value=1, max_bars_back=100)

rsi_length = input(14, "RSI Length", group="MOMENTUM")
rsi_threshold = input(60, "RSI Buy Threshold", group="MOMENTUM")
sr_lookback = input(20, "Support/Resistance Lookback", group="SUPPORT & RESISTANCE")
volume_mult = input(1.5, "Volume Multiplier", group="VOLUME")
profit_target_pct = input(2.5, "Profit Target %", group="EXIT")
stop_loss_pct = input(1.33, "Stop Loss %", group="EXIT")
max_hold_bars = input(180, "Max Hold Bars (30min on 5m tf)", group="EXIT")

// RSI Momentum
rsi = ta.rsi(close, rsi_length)
rsi_bullish = rsi > rsi_threshold

// Support & Resistance
swing_high = ta.highest(high, sr_lookback)
swing_low = ta.lowest(low, sr_lookback)
resistance = swing_high[1]
support = swing_low[1]

// Breakout Detection
is_breakout = close > resistance and close[1] <= resistance

// Volume Spike
avg_volume = ta.sma(volume, 20)
is_volume_spike = volume > (avg_volume * volume_mult)

// ENTRY SIGNAL
entry_signal = is_breakout and rsi_bullish and is_volume_spike

// Position tracking
in_position = strategy.opentrades > 0
entry_price = strategy.position_avg_price
bars_held = bar_index - strategy.opentrades.entry_bar_index(0)

// Exit levels
profit_target = entry_price * (1 + profit_target_pct / 100)
stop_loss = entry_price * (1 - stop_loss_pct / 100)

// Exit conditions
target_hit = in_position and close >= profit_target
sl_hit = in_position and close <= stop_loss
time_exit = in_position and bars_held >= max_hold_bars

// EXECUTE TRADES
if entry_signal and not in_position
    strategy.entry("LONG", strategy.long, comment="SCALP ENTRY")

if target_hit
    strategy.close("LONG", comment="TARGET HIT")
else if sl_hit
    strategy.close("LONG", comment="STOP LOSS HIT")
else if time_exit
    strategy.close("LONG", comment="TIME EXIT")

// PLOT ENTRY SIGNALS (must be outside if statement)
plotshape(entry_signal ? 1 : na, title="ENTRY SIGNAL", style=shape.labelup, location=location.belowbar, color=color.new(color.green, 0), size=size.large, text="🟢 BUY")

// PLOT EXIT SIGNALS
plotshape(target_hit ? 1 : na, title="TARGET HIT", style=shape.labeldown, location=location.abovebar, color=color.new(color.lime, 0), size=size.large, text="🎯 TARGET")
plotshape(sl_hit ? 1 : na, title="STOP HIT", style=shape.labeldown, location=location.abovebar, color=color.new(color.red, 0), size=size.large, text="🛑 STOP")
plotshape(time_exit and not target_hit and not sl_hit ? 1 : na, title="TIME EXIT", style=shape.labeldown, location=location.abovebar, color=color.new(color.orange, 0), size=size.large, text="⏰ TIME")

// LABELS FOR ENTRY
if entry_signal
    entry_text = "WHY ENTER:\n✓ BREAKOUT above $" + str.tostring(resistance, "#.00") + "\n✓ RSI = " + str.tostring(rsi, "0.0") + " > 60\n✓ Volume " + str.tostring(volume/avg_volume, "0.0") + "x avg"
    label.new(bar_index, low - (high - low) * 0.15, text=entry_text, color=color.new(color.green, 80), textcolor=color.white, style=label.style_label_up, size=size.small)

// LABELS FOR TARGET EXIT
if target_hit
    exit_text = "WHY EXIT:\n✓ Target +2.5% Hit\n✓ Profit: $" + str.tostring((close - entry_price) * 100, "0.00")
    label.new(bar_index, high + (high - low) * 0.10, text=exit_text, color=color.new(color.lime, 80), textcolor=color.white, style=label.style_label_down, size=size.small)

// LABELS FOR STOP LOSS EXIT
if sl_hit
    exit_text = "WHY EXIT:\n✗ Stop -1.33% Hit\n✗ Loss: $" + str.tostring((entry_price - close) * 100, "0.00")
    label.new(bar_index, high + (high - low) * 0.10, text=exit_text, color=color.new(color.red, 80), textcolor=color.white, style=label.style_label_down, size=size.small)

// LABELS FOR TIME EXIT
if time_exit and not target_hit and not sl_hit
    pnl_pct = (close - entry_price) / entry_price * 100
    exit_text = "WHY EXIT:\n⏰ 30min Timeout\n📊 P&L: " + str.tostring(pnl_pct, "0.00") + "%"
    label.new(bar_index, high + (high - low) * 0.10, text=exit_text, color=color.new(color.orange, 80), textcolor=color.white, style=label.style_label_down, size=size.small)

// PLOT RESISTANCE & SUPPORT
plot(resistance, title="Resistance", color=color.new(color.red, 50), linewidth=2, style=plot.style_dashed)
plot(support, title="Support", color=color.new(color.blue, 50), linewidth=2, style=plot.style_dashed)

// PLOT PROFIT TARGET & STOP LOSS (only when in position)
plot(in_position ? profit_target : na, title="Profit Target", color=color.new(color.green, 50), linewidth=2, style=plot.style_dashed)
plot(in_position ? stop_loss : na, title="Stop Loss", color=color.new(color.red, 50), linewidth=2, style=plot.style_dashed)

// RSI INDICATOR
plot(rsi, title="RSI", color=color.blue, linewidth=1)
hline(60, "RSI 60", color=color.orange, linestyle=hline.style_dashed)
hline(50, "RSI 50", color=color.gray, linestyle=hline.style_dotted)

// VOLUME INDICATOR
volume_color = volume > avg_volume * 1.5 ? color.new(color.green, 70) : color.new(color.gray, 70)
plot(volume, title="Volume", color=volume_color, style=plot.style_columns)
plot(avg_volume * 1.5, title="Volume Threshold", color=color.orange, linewidth=1)

// ALERTS
alertcondition(entry_signal, title="GOOGL BUY SIGNAL", message="🟢 GOOGL ENTRY: Breakout confirmed at {{close}}")
alertcondition(target_hit, title="GOOGL TARGET HIT", message="🎯 GOOGL TARGET: +2.5% at {{close}}")
alertcondition(sl_hit, title="GOOGL STOP HIT", message="🛑 GOOGL STOP: -1.33% at {{close}}")
